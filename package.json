{
  "name": "radion-examples",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Runnable examples for building on Radion's live Polymarket WebSocket data, using Bun.",
  "engines": {
    "bun": ">=1.4.0"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "copytrade": "bun run websockets/01-copytrading-mirror/index.ts",
    "wallet-alerts": "bun run websockets/02-wallet-alerts/index.ts",
    "whales": "bun run websockets/03-whale-trade-feed/index.ts",
    "ticker": "bun run websockets/04-live-price-ticker/index.ts",
    "market": "bun run websockets/05-market-monitor/index.ts",
    "mempool": "bun run websockets/06-mempool-early-alerts/index.ts",
    "resolutions": "bun run websockets/07-resolution-watcher/index.ts",
    "resilient": "bun run websockets/08-resilient-client/index.ts"
  }
}
